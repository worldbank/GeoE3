{
  "include": [
    "geoe3",
    "test"
  ],
  "exclude": [
    "**/__pycache__",
    "build",
    "dist",
    ".venv",
    ".vscode",
    ".vscode-extensions"
  ],
  "extraPaths": [
    "geoe3/extlibs"
  ],
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false
}